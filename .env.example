# =============================================================================
# GradAtlas - Graduate Application Tracker
# Environment Variables Template
# Copy this file to .env and replace placeholder values
# =============================================================================

# --------------------------------------------------------------------------
# DATABASE
# PostgreSQL database connection (Supabase recommended)
# --------------------------------------------------------------------------

# Pooled connection (recommended for Vercel production)
DATABASE_URL="postgresql://postgres:your-password@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"

# --------------------------------------------------------------------------
# NEXTAUTH
# Generate secret with:
# openssl rand -base64 32
# --------------------------------------------------------------------------

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"

# --------------------------------------------------------------------------
# GOOGLE OAUTH
# Create credentials at:
# https://console.cloud.google.com/apis/credentials
#
# Redirect URI examples:
# Local:
# http://localhost:3000/api/auth/callback/google
#
# Production:
# https://your-app.vercel.app/api/auth/callback/google
# --------------------------------------------------------------------------

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --------------------------------------------------------------------------
# APP
# --------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME="GradAtlas"